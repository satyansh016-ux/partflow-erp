# Copy this file to .env and fill in real values before running the app.

# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=production

# Database
# --- Local development (default, zero setup): ---
# DATABASE_URL=sqlite:///partflow.db
#
# --- Supabase / production Postgres: ---
# Get this from Supabase Dashboard > Project Settings > Database > Connection string (URI, "Session pooler" for most hosts)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=sqlite:///partflow.db

# Super Admin bootstrap (used by seed.py on first run only)
SUPERADMIN_EMAIL=admin@partflow.com
SUPERADMIN_PASSWORD=ChangeMe123!

# Session cookie security (set to true when served over HTTPS)
SESSION_COOKIE_SECURE=false

# Backup & Recovery
# BACKUP_ENCRYPTION_KEY and BACKUP_TRIGGER_SECRET are auto-generated into this
# file by `python seed.py` the first time you run it — you don't need to set
# them yourself. Back up BACKUP_ENCRYPTION_KEY separately from your database;
# without it, existing backup files cannot be decrypted.
# ENABLE_IN_APP_SCHEDULER=true   # set to false for multi-worker production deployments (see README)
# BACKUP_RETENTION_DAILY=7
# BACKUP_RETENTION_WEEKLY=4
# BACKUP_RETENTION_MONTHLY=12

# Support Center
SUPPORT_EMAIL=support@partflow.com
# SUPPORT_WHATSAPP_NUMBER=919999999999   # country code + number, no + or spaces
